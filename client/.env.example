# Supabase frontend
# In local Vite development, you can also use /supabase to route through the dev proxy.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Optional: keep this as the real hosted URL when VITE_SUPABASE_URL uses /supabase locally.
VITE_SUPABASE_PUBLIC_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
# Keep both during cutover because current code reads ANON first and falls back to PUBLISHABLE.
VITE_SUPABASE_ANON_KEY=your_publishable_key_here
VITE_ADMIN_AUTH_PROVIDER=supabase
VITE_STORAGE_UPLOAD_PROVIDER=supabase
VITE_SUPABASE_STORAGE_SIGNED_UPLOAD_ENDPOINT=https://your-project-ref.supabase.co/functions/v1/signed-upload
VITE_ADMIN_ACCOUNT_SYNC_ENDPOINT=https://your-project-ref.supabase.co/functions/v1/admin-account-sync

# Payments
VITE_TOSS_PAYMENTS_ENABLED=false
VITE_TOSS_PAYMENTS_CLIENT_KEY=live_ck_your_toss_client_key_here
VITE_TOSS_PAYMENTS_MOCK_MODE=false

# Maps / security / local bridge
VITE_NAVER_MAP_CLIENT_ID=your_naver_map_client_id
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
VITE_LOCAL_ADMIN_DATA_BRIDGE_URL=http://localhost:8790

# Optional frontend integrations
VITE_GOOGLE_CHAT_WEBHOOK_URL=
VITE_CLAUDE_API_KEY=
VITE_GEMINI_API_KEY=
VITE_GA4_MEASUREMENT_ID=

# Google Ads 검색광고 전환 추적
# Google Ads 계정 → 도구 → 전환 → 새 전환 액션 생성 후 아래 값 입력
# AW-XXXXXXXXXX 형식 (계정 ID)
VITE_GOOGLE_ADS_ID=
# 전환 액션별 라벨 (AW-XXXXXXXXXX/XXXXXXXXXXXX 중 / 뒤 부분)
VITE_GOOGLE_ADS_CONVERSION_LABEL=

# Legacy Firebase compatibility
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
