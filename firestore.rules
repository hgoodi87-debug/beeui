rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ Beeliber Zero-Trust Security Policy v2 (Verified by Biki)
    
    // Helper: Check if administrative user
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: Check if Super Admin 🛡️
    function isSuperAdmin() {
      return isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super';
    }

    // Helper: Valid Booking
    function isValidBooking() {
      let data = request.resource.data;
      return data.userName is string && 
             data.userEmail is string && 
             data.serviceType in ['DELIVERY', 'STORAGE'] &&
             data.finalPrice is number &&
             data.pickupDate is string;
    }

    // Bookings: Public creation, Restricted read/update
    match /bookings/{bookingId} {
      allow create: if isValidBooking(); // 🛡️ Zero-Trust Security Applied
      allow read, update, delete: if isAdmin() || (request.auth != null && (resource == null || resource.data.userId == request.auth.uid));
    }

    // Admins: ONLY Admins can see or list admins. No public leaks! 🛡️
    match /admins/{adminId} {
      allow get: if isAdmin() || (request.auth != null && request.auth.uid == adminId);
      allow list: if isAdmin();
      // [스봉이] 인증된 사용자가 본인의 신분증(UID)을 직접 등록/수정할 수 있도록 허용합니다. 💅✨
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == adminId);
    }

    // Expenditures & Closings: Admin only
    match /expenditures/{expId} {
      allow read, write: if isAdmin();
    }

    match /daily_closings/{closeId} {
      allow read, write: if isAdmin();
    }

    // Locations: Public Read, Admin Write
    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings: Public read for general config, Admin Write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promo Codes: Admin Only for list/write, Public Get (validation only)
    match /promo_codes/{codeId} {
      allow get: if true; // Used for validation in booking
      allow list, write: if isAdmin();
    }

    // Helper: Valid Inquiry
    function isValidInquiry() {
      let data = request.resource.data;
      return data.companyName is string &&
             data.contactName is string &&
             data.email is string &&
             data.phone is string &&
             data.message is string;
    }

    // Inquiries: Protected creation, Admin view
    match /inquiries/{inqId} {
      allow create: if isValidInquiry(); // 🛡️ Zero-Trust Security Applied
      allow read, write: if isAdmin();
    }

    // 🛡️ [스봉이] 감사 로그: 모든 관리자가 쓰기 가능, Super Admin만 읽기 가능
    match /audit_logs/{logId} {
      allow create: if isAdmin();
      allow read: if isSuperAdmin();
      allow update, delete: if false; // 감사 로그는 수정/삭제 불가! 🔐
    }
  }
}
