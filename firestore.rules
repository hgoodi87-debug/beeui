service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ Beeliber Zero-Trust Security Policy v2 (Verified by Biki)
    
    // Helper: Check if administrative user
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Bookings: Public creation, Restricted read/update
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (request.auth != null && (resource == null || resource.data.userId == request.auth.uid));
    }

    // Admins: ONLY Admins can see or list admins. No public leaks! 🛡️
    match /admins/{adminId} {
      allow get: if isAdmin() || (request.auth != null && request.auth.uid == adminId);
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Expenditures & Closings: Admin only
    match /expenditures/{expId} {
      allow read, write: if isAdmin();
    }

    match /daily_closings/{closeId} {
      allow read, write: if isAdmin();
    }

    // Locations: Public Read, Admin Write
    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings: Admin only
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // Promo Codes: Admin Only for list/write, Public Get (validation only)
    match /promo_codes/{codeId} {
      allow get: if true; // Used for validation in booking
      allow list, write: if isAdmin();
    }

    // Inquiries: Protected creation, Admin view
    match /inquiries/{inqId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
