service cloud.firestore {
  match /databases/{database}/documents {
    // Zero-Trust Security Policy 💅
    
    // User bookings: Only owner or admin can read/write
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // Admins (HR): Necessary for login and personnel management 💅
    match /admins/{adminId} {
      allow read: if true; // Temporary allow for login logic. 
      allow write: if request.auth != null; 
    }

    // Expenditures & Closings: Admin only
    match /expenditures/{expId} {
      allow read, write: if request.auth != null;
    }

    match /daily_closings/{closeId} {
      allow read, write: if request.auth != null;
    }

    // Locations & Settings
    match /locations/{locationId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Promo Codes & Inquiries
    match /promo_codes/{codeId} {
      allow read: if true; // Public for validation
      allow write: if request.auth != null;
    }

    match /inquiries/{inqId} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }
  }
}
