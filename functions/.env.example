# Supabase server/runtime
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Keep both during migration because current scripts still read SUPABASE_SECRET_KEY.
SUPABASE_SECRET_KEY=your_service_role_key_here
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/beeliber

# Supabase migration / admin bootstrap
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change_me
FIRST_ADMIN_DISPLAY_NAME=HQ Admin
FIRST_ADMIN_EMPLOYEE_NAME=HQ Admin
FIRST_ADMIN_EMPLOYEE_CODE=EMP-HQ-0001
FIRST_ADMIN_BRANCH_CODE=HQ-SEOUL
FIRST_ADMIN_BRANCH_NAME=Beeliber HQ
FIRST_ADMIN_BRANCH_TYPE=HQ
FIRST_ADMIN_JOB_TITLE=CEO

# Firebase bridge / migration
FIREBASE_PROJECT_ID=beeliber-main
FIREBASE_SERVICE_ACCOUNT_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
SUPABASE_APPLY=false
SUPABASE_AUTH_UPDATE_EXISTING=false
SUPABASE_AUTH_UPDATE_PASSWORD=false
SUPABASE_ALLOW_SYNTHETIC_EMAIL=false
SUPABASE_SYNTHETIC_EMAIL_DOMAIN=staff.bee-liber.invalid
SUPABASE_DEFAULT_HQ_BRANCH_CODE=HQ-SEOUL
SUPABASE_SYNC_PREVIEW_LIMIT=20

# Notifications / external integrations
SMTP_USER=ceo@bee-liber.com
SMTP_PASS=
GOOGLE_CHAT_WEBHOOK_URL=          # 챗봇 메시지 채널
GOOGLE_CHAT_BOOKING_WEBHOOK_URL=  # 예약 알림 전용 채널 (미설정 시 챗봇 채널로 폴백)
GOOGLE_CHAT_ESCALATE_WEBHOOK_URL= # 상담원 연결 전용 채널 (미설정 시 챗봇 채널로 폴백)
GOOGLE_PLACES_API_KEY=
TOSS_PAYMENTS_SECRET_KEY=
TOSS_SECRET_KEY=

# PayPal (해외 카드 결제 Edge Function)
# PAYPAL_MODE: "sandbox" (개발) | "live" (실배포)
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# Legacy function agents
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
LENDING_API_KEY=
FE_API_KEY=
PAY_API_KEY=
