rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: Check if administrative user from Firestore
    function isAdmin() {
      return request.auth != null && 
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.role in ['super', 'branch', 'staff', 'partner', 'driver', 'finance', 'cs'];
    }

    // 📍 Locations: Public read for branding/guide images, Admin only write
    match /locations/{locationId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Helper: File constraint
    function isSmallFile() {
      return request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }

    // 📦 Bookings: Baggage photos and receipts (Auth required)
    match /bookings/{bookingId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSmallFile();
    }

    // 👤 User Private Space: Locked to the UID
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: Deny if not matched above
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
